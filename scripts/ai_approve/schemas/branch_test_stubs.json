{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["stubs"],
  "properties": {
    "stubs": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["for_file", "for_line", "for_function", "stub_code"],
        "properties": {
          "for_file": { "type": "string", "minLength": 1 },
          "for_line": { "type": "integer", "minimum": 1 },
          "for_function": { "type": "string", "minLength": 1 },
          "stub_code": { "type": "string", "minLength": 1, "maxLength": 4000 }
        }
      }
    }
  }
}
