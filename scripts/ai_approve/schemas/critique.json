{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["drops", "concerns"],
  "properties": {
    "drops": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["comment_index", "reason"],
        "properties": {
          "comment_index": { "type": "integer", "minimum": 0 },
          "reason": {
            "type": "string",
            "enum": [
              "expected_text_mismatch",
              "claim_unsupported_by_file",
              "claim_contradicts_file",
              "uses_undefined_term",
              "speculation_beyond_evidence"
            ]
          }
        }
      }
    },
    "concerns": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 }
    }
  }
}
