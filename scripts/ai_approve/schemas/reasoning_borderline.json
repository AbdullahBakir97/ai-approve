{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "reasoning"],
  "properties": {
    "decision": { "type": "string", "enum": ["proceed", "escalate_to_hard_block"] },
    "reasoning": { "type": "string", "maxLength": 1000 }
  }
}
