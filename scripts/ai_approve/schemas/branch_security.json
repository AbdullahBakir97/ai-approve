{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "confidence", "certainty", "summary", "comments"],
  "properties": {
    "verdict": { "type": "string", "enum": ["APPROVE", "REQUEST_CHANGES", "COMMENT"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "certainty": { "type": "string", "enum": ["fully_understood", "minor_uncertainty", "significant_uncertainty"] },
    "summary": { "type": "string", "maxLength": 1500 },
    "comments": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "line", "expected_text", "claim", "suggested_text", "severity"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "expected_text": { "type": "string" },
          "claim": { "type": "string", "maxLength": 600 },
          "suggested_text": { "type": ["string", "null"] },
          "severity": { "type": "string", "enum": ["info", "nit", "warn", "major", "blocker"] }
        }
      }
    }
  }
}
